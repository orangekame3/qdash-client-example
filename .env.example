# Required: QDash API base URL.
# Local development usually uses http://localhost:5715.
# If your deployment exposes the API under a prefix, include it here, for example
# https://your-qdash-instance/api.
QDASH_BASE_URL=http://localhost:5715
QDASH_API_TOKEN=your-api-token

# Optional: set only when your QDash instance requires project-scoped access.
QDASH_PROJECT_ID=

# Optional: set only when QDash is behind Cloudflare Access.
QDASH_CF_ACCESS_CLIENT_ID=
QDASH_CF_ACCESS_CLIENT_SECRET=
